# Database — same PostgreSQL as Dashboarduz
DATABASE_URL=postgresql://user:password@host/dbname

# JWT — must match Dashboarduz JWT_SECRET if sharing sessions, or use a different one
JWT_SECRET=change-me-in-production-minimum-32-characters
JWT_EXPIRES_IN=7d

# Server
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000

# Telegram report bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=
REPORT_CRON_SECRET=
REPORT_TIMEZONE=Asia/Tashkent

# Face ID student attendance webhook
FACEID_WEBHOOK_SECRET=
FACEID_TENANT_ID=
