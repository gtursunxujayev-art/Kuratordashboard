{
  "name": "@kuratordashboard/api",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20 <25"
  },
  "description": "Kuratordashboard API",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "node --env-file=.env --require tsx/cjs --watch --watch-preserve-output src/index.ts",
    "build": "tsc",
    "start": "npm run migrate:deploy --workspace @kuratordashboard/db && node dist/index.js",
    "type-check": "tsc --noEmit",
    "db:generate": "npm run generate --workspace @kuratordashboard/db",
    "db:migrate": "npm run migrate --workspace @kuratordashboard/db",
    "db:studio": "npm run studio --workspace @kuratordashboard/db"
  },
  "dependencies": {
    "@kuratordashboard/db": "file:../../packages/db",
    "@trpc/server": "^10.45.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "puppeteer": "^24.43.0",
    "superjson": "^2.2.6",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
